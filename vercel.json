{
  "functions": {
    "api/analyze.py": { "maxDuration": 60, "memory": 1024 },
    "api/convert.py": { "maxDuration": 30, "memory": 1024 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
